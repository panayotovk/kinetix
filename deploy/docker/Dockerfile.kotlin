# Runtime Dockerfile for individual Kotlin/Ktor services
# Requires the kinetix-builder image to be built first
ARG SERVICE_NAME

FROM kinetix-builder:latest AS builder

FROM eclipse-temurin:21-jre-alpine

ARG SERVICE_NAME

RUN addgroup -S kinetix && adduser -S kinetix -G kinetix

WORKDIR /app

COPY --from=builder /app/${SERVICE_NAME}/build/install/${SERVICE_NAME}/ ./

RUN chown -R kinetix:kinetix /app

USER kinetix

ENTRYPOINT ["sh", "-c", "./bin/${SERVICE_NAME}"]
